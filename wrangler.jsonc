{
  "name": "aeyundian-ws",
  "main": "./worker/index.js",
  "compatibility_date": "2026-06-26",
  "compatibility_flags": ["assets_navigation_prefers_asset_serving"],
  "assets": {
    "directory": "./src/.vuepress/dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"]
  }
}
